# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# stray PAI memory dir from an unexpanded ${HOME} (script bug, not part of template)
${HOME}/

# typescript
*.tsbuildinfo
next-env.d.ts

# orange slice vendor docs (generated by npx orangeslice)
/orangeslice-docs
/AGENTS.md
